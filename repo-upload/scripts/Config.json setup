# setup the folder for config.json in powershell

$claudeDir = "$env:APPDATA\Claude"
$screenshotsDir = "$env:USERPROFILE\Pictures\Screenshots"
$configFile = "$claudeDir\claude_desktop_config.json"

New-Item -ItemType Directory -Force -Path $claudeDir | Out-Null
New-Item -ItemType Directory -Force -Path $screenshotsDir | Out-Null
New-Item -ItemType Directory -Force -Path "$env:USERPROFILE\Desktop" | Out-Null
New-Item -ItemType Directory -Force -Path "$env:USERPROFILE\Downloads" | Out-Null
New-Item -ItemType Directory -Force -Path "$env:USERPROFILE\Documents" | Out-Null

if (Test-Path $configFile) {
    Write-Host "WARNING: $configFile already exists. Not overwriting it." -ForegroundColor Yellow
    Write-Host "Open it manually and merge in the ms365/filesystem entries if needed."
} else {
    $desktop = "$env:USERPROFILE\Desktop".Replace('\','\\')
    $downloads = "$env:USERPROFILE\Downloads".Replace('\','\\')
    $documents = "$env:USERPROFILE\Documents".Replace('\','\\')
    $screenshots = "$screenshotsDir".Replace('\','\\')

    $json = @"
{
  "mcpServers": {
    "ms365": {
      "command": "npx",
      "args": ["-y", "@softeria/ms-365-mcp-server", "--org-mode"]
    },
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "$desktop",
        "$downloads",
        "$documents",
        "$screenshots"
      ]
    }
  }
}
"@

    Set-Content -Path $configFile -Value $json -Encoding UTF8
    Write-Host "Config written to $configFile" -ForegroundColor Green
}

Write-Host ""
Write-Host "Next: fully quit and restart Claude Desktop, then try an ms365 tool to trigger sign-in." -ForegroundColor Cyan
